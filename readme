/* Install imagemagic*/

//For MAC OS 86x64 arch based chips use
brew install imagemagick



//For MAC OS arm64 arch based chips clone the repository, compile and install from sources more infor https://imagemagick.org/script/install-source.php
//First install libjpeg
brew install automake make pkg-config libjpeg
//Then follow the instructions on the last raws of the installation completion logs and add exports to .zprofile file like below for my case, this will enable imagmagic to find the libjpeg library
export LDFLAGS="-L/opt/homebrew/opt/jpeg/lib"
export CPPFLAGS="-I/opt/homebrew/opt/jpeg/include"

//Then install libheif
brew install automake make pkg-config libheif

//After this only run below to configure, make and install imagmagic, so that it will contain all heic, jpeg, png deligates
$ git clone https://github.com/ImageMagick/ImageMagick.git ImageMagick-7.1.1

$ cd ImageMagick-7.1.1

//jxl was causing errors on make, so I disabled it
$ ./configure --with-jxl=no

$ make 
$ sudo make install 

brew install pkg-config

add below line into .zshrc
export CGO_CFLAGS_ALLOW="-Xpreprocessor"

run in terminal below 
go get gopkg.in/gographics/imagick.v3/imagick

/* Alternatively try Install imagemagic following https://github.com/gographics/imagick/tree/v3.4.2*/
sudo port install ImageMagick
